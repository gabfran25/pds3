<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/Tv_Nombre_Comentario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/UsuarioComentario"
        android:textStyle="bold"
        android:textColor="@color/black" />

    <TextView
        android:id="@+id/Tv_Texto_Comentario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/TextoComentario"
        android:textColor="@color/black"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/Tv_Fecha_Comentario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/FechaComentario"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="5dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/Btn_Like_Comento"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/anteslike"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="5dp"/>

        <TextView
            android:id="@+id/Tv_Likes_Comento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="12sp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="15dp"/>

        <ImageButton
            android:id="@+id/Btn_Dislike_Comento"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/antesdislike"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="5dp"/>

        <TextView
            android:id="@+id/Tv_Dislikes_Comento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="12sp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="15dp"/>

        <ImageButton
            android:id="@+id/Btn_Responder_Comento"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/respondercomentario"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="5dp"
            android:layout_marginStart="10dp"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/RvRespuestas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginTop="5dp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="8dp"/>

</LinearLayout>