<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Fragmentos.FragmentChats">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/TILBuscarUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/Et_buscar_usuario"
            android:hint="@string/Et_buscar_usuario"
            android:layout_marginHorizontal="5dp"
            android:inputType="textCapWords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </com.google.android.material.textfield.TextInputLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/RV_usuarios"
        android:layout_below="@+id/TILBuscarUsuario"
        android:layout_marginTop="5dp"
        android:padding="5dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
<!--android:text="CHATS" />-->

<!--    <TextView-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="match_parent"-->
<!--        android:text="CHATS"/>-->

    <TextView
        android:id="@+id/tvSinUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tv_sin_Usuario"
        android:visibility="gone"
        android:layout_centerInParent="true"
        android:textAlignment="center"
        android:textSize="16sp"/>

</RelativeLayout>